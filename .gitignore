# ===========================================
# COVA Website - Git Ignore
# ===========================================

# === Dependencies ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Build / Generated Files ===
# Source maps (generated by Sass)
**/*.map

# Compiled CSS if you ever add a dist/build folder
dist/
build/
*.min.css
*.min.js

# === IDE / Editor ===
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# === OS Generated Files ===
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# === Grunt specific ===
.grunt/
grunt-*.log

# === Logs & Temp ===
logs/
*.log
*.tmp
*.bak

# === Misc ===
# Local MCP tool descriptors (not part of the website)
mcps/

# Uncomment if you want to ignore environment files
# .env
# .env.local
